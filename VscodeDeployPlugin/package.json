{
    "name": "zerofinance-git",
    "displayName": "zerofinance-git",
    "description": "zerofinance-git",
    "version": "2.0.0",
    "publisher": "zerofinance",
    "repository": "https://github.com/zhaoxunyong/vs-code-git-plugin",
    "engines": {
        "vscode": "^1.30.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onCommand:extension.MavenChange",
        "onCommand:extension.StartNewFeature",
        "onCommand:extension.FinishFeature",
        "onCommand:extension.RebaseFeature",
        "onCommand:extension.StartNewRelease",
        "onCommand:extension.FinishRelease",
        "onCommand:extension.StartNewHotfix",
        "onCommand:extension.FinishHotfix",
        "onCommand:extension.GenerateCommitMessage"
    ],
    "main": "./src/extension.js",
    "contributes": {
        "configuration": {
            "type": "object",
            "title": "zerofinance-git",
            "properties": {
                "zerofinanceGit.gitScriptsUrlPreference": {
                    "type": "string",
                    "default": "https://gitlab.zerofinance.net/dave.zhao/deployPlugin/-/raw/git-flow/git-flow",
                    "description": "Gitlab url for download scripts"
                },
                "zerofinanceGit.checkGitVersion": {
                    "type": "boolean",
                    "default": false,
                    "description": "Whether or not check git version"
                },
                "zerofinanceGit.debug": {
                    "type": "boolean",
                    "default": false,
                    "description": "Enable debug logs in extension host console"
                },
                "zerofinanceGit.commitMessageModel": {
                    "type": "string",
                    "default": "new-api/GLM-5",
                    "description": "Model used by Generate Commit Message command"
                },
                "zerofinanceGit.groupName": {
                    "type": "string",
                    "default": "",
                    "enum": [
                        "",
                        "a",
                        "b"
                    ],
                    "enumDescriptions": [
                        "Please select a group before running any task",
                        "Group A",
                        "Group B"
                    ],
                    "description": "Required group name for running tasks. Must be a or b."
                }
            }
        },
        "commands": [
            {
                "command": "extension.MavenChange",
                "title": "Maven Change"
            },
            {
                "command": "extension.StartNewFeature",
                "title": "Start New Feature"
            },
            {
                "command": "extension.FinishFeature",
                "title": "Finish Feature"
            },
            {
                "command": "extension.RebaseFeature",
                "title": "Rebase Feature"
            },
            {
                "command": "extension.StartNewRelease",
                "title": "Start New Release"
            },
            {
                "command": "extension.FinishRelease",
                "title": "Finish Release"
            },
            {
                "command": "extension.StartNewHotfix",
                "title": "Start New Hotfix"
            },
            {
                "command": "extension.FinishHotfix",
                "title": "Finish Hotfix"
            },
            {
                "command": "extension.GenerateCommitMessage",
                "title": "Generate Commit Message"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "submenu": "zerogit.menu",
                    "group": "zerogit"
                }
            ],
            "terminal/context": [
                {
                    "submenu": "zerogit.menu",
                    "group": "zerogit"
                }
            ],
            "view/title": [
                {
                    "submenu": "zerogit.menu",
                    "group": "zerogit",
                    "when": "view == terminal"
                }
            ],
            "zerogit.menu": [
                {
                    "command": "extension.GenerateCommitMessage",
                    "group": "0_commit"
                },
                {
                    "submenu": "zerogit.maven.menu",
                    "group": "1_maven"
                },
                {
                    "submenu": "zerogit.feature.menu",
                    "group": "2_feature"
                },
                {
                    "submenu": "zerogit.release.menu",
                    "group": "3_release"
                },
                {
                    "submenu": "zerogit.hotfix.menu",
                    "group": "4_hotfix"
                }
            ],
            "zerogit.maven.menu": [
                {
                    "command": "extension.MavenChange",
                    "group": "0_maven"
                }
            ],
            "zerogit.feature.menu": [
                {
                    "command": "extension.StartNewFeature",
                    "group": "0_start"
                },
                {
                    "command": "extension.FinishFeature",
                    "group": "1_finish"
                },
                {
                    "command": "extension.RebaseFeature",
                    "group": "2_rebase"
                }
            ],
            "zerogit.release.menu": [
                {
                    "command": "extension.StartNewRelease",
                    "group": "0_start"
                },
                {
                    "command": "extension.FinishRelease",
                    "group": "1_finish"
                }
            ],
            "zerogit.hotfix.menu": [
                {
                    "command": "extension.StartNewHotfix",
                    "group": "0_start"
                },
                {
                    "command": "extension.FinishHotfix",
                    "group": "1_finish"
                }
            ]
        },
        "submenus": [
            {
                "id": "zerogit.menu",
                "label": "ZeroGit"
            },
            {
                "id": "zerogit.maven.menu",
                "label": "Maven"
            },
            {
                "id": "zerogit.feature.menu",
                "label": "Feature"
            },
            {
                "id": "zerogit.release.menu",
                "label": "Release"
            },
            {
                "id": "zerogit.hotfix.menu",
                "label": "Hotfix"
            }
        ]
    },
    "scripts": {
        "postinstall": "node ./node_modules/vscode/bin/install",
        "test": "node ./node_modules/vscode/bin/test"
    },
    "devDependencies": {
        "@types/mocha": "^2.2.42",
        "@types/node": "^10.12.21",
        "eslint": "^5.13.0",
        "typescript": "^3.3.1",
        "vscode": "^1.1.37"
    },
    "dependencies": {
        "axios": "^0.18.0",
        "tmp": "0.0.33"
    }
}