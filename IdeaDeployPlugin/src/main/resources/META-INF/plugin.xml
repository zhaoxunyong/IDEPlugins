<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN. It cannot be changed between the plugin versions. -->
    <id>com.zerofinance.ZeroGitDeployToolkit</id>

    <!-- Public plugin name should be written in Title Case.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-name -->
    <name>Zero Git Deploy Toolkit</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor email="dave.zhao@zerofinance.com" url="https://www.zerofinance.com">ZeroFinance</vendor>

    <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
         Simple HTML elements (text formatting, paragraphs, and lists) can be added inside of <![CDATA[ ]]> tag.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-description -->
    <description><![CDATA[
    A Zero Git Deploy Toolkit for Intellij IDEA, which can help us deploy git project more convenient. <br />
    ZeroGit Flow commands are executed by shared scripts to keep IDEA/VS Code workflows consistent. <br /><br />
    <b>features:</b>
    <ul>
        <li>1. Maven Change</li>
        <li>2. Start New Feature</li>
        <li>3. Finish Feature</li>
        <li>4. Rebase Feature</li>
        <li>5. Start New Release</li>
        <li>6. Finish Release</li>
        <li>7. Start New Hotfix</li>
        <li>8. Finish Hotfix</li>
    </ul>
    ]]></description>

    <change-notes><![CDATA[
    <ul>
        <li>2.0.0 : Refactored to ZeroGit-only flow with 7 commands and removed legacy release/newBranch/changeVersion/anyTool actions. </li>
        <li>1.0.11 : Fixed some issues. </li>
        <li>1.0.10 : Fixed some issues. </li>
        <li>1.0.9 : Fixed some issues. </li>
        <li>1.0.8 : Fixed an incompatible issue. </li>
        <li>1.0.7 : Fixed some issues. </li>
        <li>1.0.6 : Added Modifying dependency versions. </li>
        <li>1.0.5 : Fixed some issues. </li>
        <li>1.0.4 : Skipping local repository confirm if any files were changed. </li>
        <li>1.0.3 : Fixed some issues. </li>
        <li>1.0.2 : Changed the icons and fixed some issues. </li>
        <li>1.0.1 : Added to toolbar and popup menu. </li>
        <li>1.0.0 : init </li>
    </ul>
    ]]>
    </change-notes>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <!-- Extension points defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">
        <!-- Add your extensions here -->
        <toolWindow id="GitDeployPlugin"
                    icon="AllIcons.Actions.ChangeView"
                    anchor="bottom"
                    factoryClass="com.zerofinance.zerogitdeploy.ZeroGitDeploy"></toolWindow>
        <notificationGroup id="Zero Notification Group"
                           displayType="BALLOON" />
        <applicationConfigurable instance="com.zerofinance.zerogitdeploy.setting.ZeroGitDeploySetting" dynamic="true"/>
    </extensions>

    <actions>
        <!-- main menu -->
        <group id="ZeroMainAction" text="ZeroGit" description="A git deploy plugin tool">
            <add-to-group group-id="MainMenu"  anchor="after" relative-to-action="ToolsMenu" />
            <group id="ZeroMainMavenSubMenu" text="Maven" popup="true" icon="/icons/mavenMenu.svg">
                <action id="MavenChangeMainMenu" class="com.zerofinance.zerogitdeploy.action.MavenChangeAction" icon="AllIcons.Actions.EditSource" text="Maven Change" description="ZeroGit Maven Change" />
            </group>
            <group id="ZeroMainFeatureSubMenu" text="Feature" popup="true" icon="/icons/featureMenu.svg">
                <action id="StartNewFeatureMainMenu" class="com.zerofinance.zerogitdeploy.action.StartNewFeatureAction" icon="AllIcons.Vcs.Branch" text="Start New Feature" description="ZeroGit Start New Feature" />
                <action id="FinishFeatureMainMenu" class="com.zerofinance.zerogitdeploy.action.FinishFeatureAction" icon="AllIcons.Vcs.Branch" text="Finish Feature" description="ZeroGit Finish Feature" />
                <action id="RebaseFeatureMainMenu" class="com.zerofinance.zerogitdeploy.action.RebaseFeatureAction" icon="AllIcons.Actions.MoveTo2" text="Rebase Feature" description="ZeroGit Rebase Feature" />
            </group>
            <group id="ZeroMainReleaseSubMenu" text="Release" popup="true" icon="/icons/releaseMenu.svg">
                <action id="StartNewReleaseMainMenu" class="com.zerofinance.zerogitdeploy.action.StartNewReleaseAction" icon="AllIcons.Actions.Execute" text="Start New Release" description="ZeroGit Start New Release" />
                <action id="FinishReleaseMainMenu" class="com.zerofinance.zerogitdeploy.action.FinishReleaseAction" icon="AllIcons.Actions.Commit" text="Finish Release" description="ZeroGit Finish Release" />
            </group>
            <group id="ZeroMainHotfixSubMenu" text="Hotfix" popup="true" icon="/icons/hotfixMenu.svg">
                <action id="StartNewHotfixMainMenu" class="com.zerofinance.zerogitdeploy.action.StartNewHotfixAction" icon="AllIcons.Actions.Execute" text="Start New Hotfix" description="ZeroGit Start New Hotfix" />
                <action id="FinishHotfixMainMenu" class="com.zerofinance.zerogitdeploy.action.FinishHotfixAction" icon="AllIcons.Actions.Commit" text="Finish Hotfix" description="ZeroGit Finish Hotfix" />
            </group>
        </group>

        <!-- popup menu -->
        <!-- https://xujin.org/guides/idea-01/ -->
        <group id="ZeroPopupMenuAction" text="ZeroGit" popup="true" icon="AllIcons.Actions.Colors">
            <separator/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="after" relative-to-action="WeighingNewGroup" />
            <group id="ZeroPopupMavenSubMenu" text="Maven" popup="true" icon="/icons/mavenMenu.svg">
                <action id="MavenChangePopupMenu" class="com.zerofinance.zerogitdeploy.action.MavenChangeAction" icon="AllIcons.Actions.EditSource" text="Maven Change" description="ZeroGit Maven Change" />
            </group>
            <group id="ZeroPopupFeatureSubMenu" text="Feature" popup="true" icon="/icons/featureMenu.svg">
                <action id="StartNewFeaturePopupMenu" class="com.zerofinance.zerogitdeploy.action.StartNewFeatureAction" icon="AllIcons.Vcs.Branch" text="Start New Feature" description="ZeroGit Start New Feature" />
                <action id="FinishFeaturePopupMenu" class="com.zerofinance.zerogitdeploy.action.FinishFeatureAction" icon="AllIcons.Vcs.Branch" text="Finish Feature" description="ZeroGit Finish Feature" />
                <action id="RebaseFeaturePopupMenu" class="com.zerofinance.zerogitdeploy.action.RebaseFeatureAction" icon="AllIcons.Actions.MoveTo2" text="Rebase Feature" description="ZeroGit Rebase Feature" />
            </group>
            <group id="ZeroPopupReleaseSubMenu" text="Release" popup="true" icon="/icons/releaseMenu.svg">
                <action id="StartNewReleasePopupMenu" class="com.zerofinance.zerogitdeploy.action.StartNewReleaseAction" icon="AllIcons.Actions.Execute" text="Start New Release" description="ZeroGit Start New Release" />
                <action id="FinishReleasePopupMenu" class="com.zerofinance.zerogitdeploy.action.FinishReleaseAction" icon="AllIcons.Actions.Commit" text="Finish Release" description="ZeroGit Finish Release" />
            </group>
            <group id="ZeroPopupHotfixSubMenu" text="Hotfix" popup="true" icon="/icons/hotfixMenu.svg">
                <action id="StartNewHotfixPopupMenu" class="com.zerofinance.zerogitdeploy.action.StartNewHotfixAction" icon="AllIcons.Actions.Execute" text="Start New Hotfix" description="ZeroGit Start New Hotfix" />
                <action id="FinishHotfixPopupMenu" class="com.zerofinance.zerogitdeploy.action.FinishHotfixAction" icon="AllIcons.Actions.Commit" text="Finish Hotfix" description="ZeroGit Finish Hotfix" />
            </group>
        </group>

        <!-- toolbar -->
        <group id="ZeroToolbarAction" icon="AllIcons.Actions.Colors">
            <add-to-group group-id="ToolbarRunGroup" anchor="first" />
            <!-- icon can see: https://intellij-icons.jetbrains.design/ -->
            <action class="com.zerofinance.zerogitdeploy.action.ZeroToolbarLabelAction" id="ZeroToolbarLabelAction" />
            <action id="MavenChangeToolbar" class="com.zerofinance.zerogitdeploy.action.MavenChangeAction" icon="AllIcons.Actions.EditSource" text="Maven Change" description="ZeroGit Maven Change" />
            <action id="StartNewFeatureToolbar" class="com.zerofinance.zerogitdeploy.action.StartNewFeatureAction" icon="AllIcons.Vcs.Branch" text="Start New Feature" description="ZeroGit Start New Feature" />
            <action id="FinishFeatureToolbar" class="com.zerofinance.zerogitdeploy.action.FinishFeatureAction" icon="AllIcons.Vcs.Branch" text="Finish Feature" description="ZeroGit Finish Feature" />
            <action id="RebaseFeatureToolbar" class="com.zerofinance.zerogitdeploy.action.RebaseFeatureAction" icon="AllIcons.Actions.MoveTo2" text="Rebase Feature" description="ZeroGit Rebase Feature" />
            <action id="StartNewReleaseToolbar" class="com.zerofinance.zerogitdeploy.action.StartNewReleaseAction" icon="AllIcons.Actions.Execute" text="Start New Release" description="ZeroGit Start New Release" />
            <action id="FinishReleaseToolbar" class="com.zerofinance.zerogitdeploy.action.FinishReleaseAction" icon="AllIcons.Actions.Commit" text="Finish Release" description="ZeroGit Finish Release" />
            <action id="StartNewHotfixToolbar" class="com.zerofinance.zerogitdeploy.action.StartNewHotfixAction" icon="AllIcons.Actions.Execute" text="Start New Hotfix" description="ZeroGit Start New Hotfix" />
            <action id="FinishHotfixToolbar" class="com.zerofinance.zerogitdeploy.action.FinishHotfixAction" icon="AllIcons.Actions.Commit" text="Finish Hotfix" description="ZeroGit Finish Hotfix" />
            <separator/>
        </group>
    </actions>
</idea-plugin>